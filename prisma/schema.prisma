generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum OrderStatus {
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PIX_MANUAL
  PIX_AUTOMATIC
  CASH
  CREDIT_CARD
  DEBIT_CARD
  COURTESY
  NFC_BALANCE
  OTHER
}

enum PaymentProvider {
  MANUAL
  MERCADO_PAGO
  STONE
  PAGSEGURO
  CIELO
  GETNET
  OTHER
}

enum PaymentEnvironment {
  SANDBOX
  PRODUCTION
}

enum PaymentContextType {
  EVENT
  ONLINE_STORE
  POS
}

enum PaymentTransactionStatus {
  CREATED
  WAITING_PAYMENT
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  EXPIRED
  ERROR
}

enum PaymentTerminalStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum PaymentRefundStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum CategorySector {
  BAR
  KITCHEN
}

enum PrintJobStatus {
  PENDING
  PRINTED
  ERROR
  CANCELLED
}

enum PrintMode {
  FULL_ORDER
  BY_SECTOR
  BOTH
}

enum PrinterSector {
  FULL_ORDER
  BAR
  KITCHEN
}

enum PrintingSource {
  ONLINE_STORE
  MANUAL_STORE
  EVENT
  MANUAL_EVENT
  TOTEM
  POS
  API
  WAITER
}

enum PrintingSector {
  COOK
  BAR
  GENERAL
}

enum PrinterConnectionType {
  TCP_IP
  SK210_LOCAL
}

enum DeviceType {
  TOTEM
  PRINTER
  CALL_SCREEN
  SK210
}

enum DeviceStatus {
  ACTIVE
  PAUSED
  OFFLINE
  MAINTENANCE
}

enum DeviceAuthStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum NfcCardType {
  CUSTOMER
  STAFF
  VIP
  COMANDA
}

enum NfcCardStatus {
  ACTIVE
  BLOCKED
  LOST
}

enum NfcReadSource {
  ADMIN_PANEL
  TOTEM
  SK210
  ACCESS_CONTROL
}

enum NfcCardTransactionType {
  TOPUP
  PURCHASE
  REFUND
  ADJUSTMENT
  BONUS
  REVERSAL
}

enum SettingsContextType {
  ORGANIZATION
  ONLINE_STORE
}

enum SettingsChannel {
  ALL
  DELIVERY
  PICKUP
  DIGITAL_MENU
  TOTEM
  COUNTER
}

enum StoreManualOverrideMode {
  AUTO
  FORCE_OPEN
  FORCE_CLOSED
}

enum BrandingTheme {
  LIGHT
  DARK
  SYSTEM
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  auditLogs AuditLog[]

  users                             User[]
  events                            Event[]
  devices                           Device[]
  catalogCategories                 CatalogCategory[]
  catalogProducts                   CatalogProduct[]
  catalogProductOptionGroups        CatalogProductOptionGroup[]
  catalogProductOptions             CatalogProductOption[]
  paymentProviderSettings           PaymentProviderSettings[]
  paymentSettings                   OrganizationPaymentSettings?
  paymentProviderCredentials        PaymentProviderCredential[]
  contextPaymentSettings            ContextPaymentSettings[]
  paymentTerminals                  PaymentTerminal[]
  paymentTransactions               PaymentTransaction[]
  paymentRefunds                    PaymentRefund[]
  paymentWebhookEvents              PaymentWebhookEvent[]
  paymentSettingsMigrationConflicts PaymentSettingsMigrationConflict[]
  onlineStoreSettings               OnlineStoreSettings[]
  deliveryFeeRules                  DeliveryFeeRule[]
  eventClosings                     EventClosing[]
  nfcCards                          NfcCard[]
  nfcCardReads                      NfcCardRead[]
  nfcCardTransactions               NfcCardTransaction[]
  organizationModules               OrganizationModule[]
  onlineStores                      OnlineStore[]
  customers                         Customer[]
  customerAddresses                 CustomerAddress[]
  interests                         Interest[]
  settings                          OrganizationSettings?
  branding                          OrganizationBranding?
  printingSettings                  OrganizationPrintingSettings?
  businessHours                     BusinessHour[]
  businessHourExceptions            BusinessHourException[]
}

model OrganizationSettings {
  id             String @id @default(cuid())
  organizationId String @unique

  legalName    String?
  document     String?
  contactEmail String?
  contactPhone String?
  whatsapp     String?
  address      String?
  city         String?
  state        String?
  postalCode   String?

  timezone String @default("America/Sao_Paulo")
  locale   String @default("pt-BR")
  currency String @default("BRL")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationBranding {
  id             String @id @default(cuid())
  organizationId String @unique

  logoUrl                String?
  lightLogoUrl           String?
  darkLogoUrl            String?
  faviconUrl             String?
  bannerDesktopUrl       String?
  bannerMobileUrl        String?
  socialImageUrl         String?
  primaryColor           String?
  secondaryColor         String?
  backgroundColor        String?
  theme                  BrandingTheme @default(SYSTEM)
  defaultProductImageUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationPrintingSettings {
  id             String @id @default(cuid())
  organizationId String @unique

  printingEnabled  Boolean @default(false)
  autoPrintEnabled Boolean @default(false)
  allowReprint     Boolean @default(true)
  splitBySector    Boolean @default(false)
  mergeCopies      Boolean @default(true)

  defaultPrinterDeviceId    String?
  kitchenPrinterDeviceId    String?
  barPrinterDeviceId        String?
  expeditionPrinterDeviceId String?

  paperSize       String  @default("80mm")
  showLogo        Boolean @default(false)
  showPrices      Boolean @default(true)
  showQrCode      Boolean @default(false)
  showPayment     Boolean @default(true)
  showOrderSource Boolean @default(true)
  showOrderNotes  Boolean @default(true)
  showItemNotes   Boolean @default(true)
  showOptions     Boolean @default(true)

  sources Json?
  sectors Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  password       String
  role           UserRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  auditLogs AuditLog[]

  organization        Organization         @relation(fields: [organizationId], references: [id])
  eventClosings       EventClosing[]
  nfcCardReads        NfcCardRead[]
  nfcCardTransactions NfcCardTransaction[]
}

model Event {
  id             String @id @default(cuid())
  organizationId String

  name String
  slug String

  primaryColor   String?
  secondaryColor String?
  logoUrl        String?
  bannerUrl      String?

  totemWelcomeMessage  String?
  totemBackgroundColor String?
  totemTextColor       String?

  auditLogs AuditLog[]

  totemShowPrices            Boolean @default(true)
  totemShowLowStock          Boolean @default(true)
  totemRequireCustomerName   Boolean @default(true)
  totemAutoResetSeconds      Int     @default(60)
  totemShowLogo              Boolean @default(true)
  totemFullscreenRecommended Boolean @default(true)

  pixEnabled      Boolean @default(false)
  pixKey          String?
  pixReceiverName String?
  pixCity         String?
  pixInstructions String?

  pixPaymentExpirationMinutes Int @default(5)

  printingEnabled  Boolean   @default(false)
  autoPrintEnabled Boolean   @default(false)
  printMode        PrintMode @default(FULL_ORDER)
  printerPaperSize String    @default("80mm")

  closed   Boolean   @default(false)
  closedAt DateTime?

  active Boolean @default(true)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  orders                 Order[]
  devices                Device[]
  eventProducts          EventProduct[]
  printJobs              EventPrintJob[]
  printers               EventPrinter[]
  contextPaymentSettings ContextPaymentSettings[]
  paymentTerminals       PaymentTerminal[]
  nfcCards               NfcCard[]
  nfcCardReads           NfcCardRead[]
  nfcCardTransactions    NfcCardTransaction[]

  closing EventClosing?

  @@unique([organizationId, slug])
}

model Order {
  id      String @id @default(cuid())
  eventId String

  deviceId   String?
  customerId String?

  customerName String?
  orderNumber  Int

  status        OrderStatus    @default(CONFIRMED)
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?

  totalInCents Int

  amountPaidInCents Int?
  changeForInCents  Int?

  paidAt       DateTime?
  paymentNotes String?

  cancelReason String?
  cancelledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  event               Event                @relation(fields: [eventId], references: [id])
  device              Device?              @relation(fields: [deviceId], references: [id])
  customer            Customer?            @relation(fields: [customerId], references: [id])
  items               OrderItem[]
  printJobs           EventPrintJob[]
  paymentTransactions PaymentTransaction[]

  @@unique([eventId, orderNumber])
  @@index([deviceId])
  @@index([customerId])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String

  productId        String?
  catalogProductId String?

  quantity         Int
  unitPriceInCents Int
  totalInCents     Int

  productName     String
  notes           String?
  pricingSnapshot Json?

  order          Order             @relation(fields: [orderId], references: [id])
  catalogProduct CatalogProduct?   @relation(fields: [catalogProductId], references: [id])
  options        OrderItemOption[]
  flavors        OrderItemFlavor[]
}

model PaymentTransaction {
  id             String  @id @default(cuid())
  organizationId String
  orderId        String?
  onlineOrderId  String?
  terminalId     String?
  deviceId       String?

  contextType PaymentContextType @default(EVENT)
  eventId     String?
  storeId     String?

  provider PaymentProvider
  status   PaymentTransactionStatus @default(CREATED)

  method PaymentMethod?

  amountInCents  Int
  idempotencyKey String? @unique

  externalId            String?
  externalReference     String?
  providerTransactionId String?
  authorizationCode     String?
  nsu                   String?
  brand                 String?
  installments          Int?

  qrCode       String?
  qrCodeBase64 String?
  pixCopyPaste String?

  gatewayStatus  String?
  gatewayMessage String?

  approvedAt  DateTime?
  rejectedAt  DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?
  expiredAt   DateTime?
  expiresAt   DateTime?

  errorMessage String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  order        Order?           @relation(fields: [orderId], references: [id])
  onlineOrder  OnlineOrder?     @relation(fields: [onlineOrderId], references: [id])
  terminal     PaymentTerminal? @relation(fields: [terminalId], references: [id])
  device       Device?          @relation(fields: [deviceId], references: [id])
  refunds      PaymentRefund[]

  @@unique([provider, externalId])
  @@index([organizationId])
  @@index([orderId])
  @@index([onlineOrderId])
  @@index([terminalId])
  @@index([deviceId])
  @@index([contextType])
  @@index([eventId])
  @@index([storeId])
  @@index([provider])
  @@index([status])
  @@index([expiresAt])
}

model CatalogCategory {
  id             String @id @default(cuid())
  organizationId String

  name String
  slug String

  sector CategorySector @default(KITCHEN)

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization        Organization     @relation(fields: [organizationId], references: [id])
  products            CatalogProduct[]
  halfAndHalfProducts CatalogProduct[] @relation("HalfAndHalfFlavorCategory")

  @@unique([organizationId, slug])
}

model CatalogProduct {
  id                String @id @default(cuid())
  organizationId    String
  catalogCategoryId String

  name         String
  slug         String
  description  String?
  imageUrl     String?
  priceInCents Int

  pricingRule                 CatalogProductPricingRule @default(STANDARD)
  supportsHalfAndHalf         Boolean                   @default(false)
  canBeUsedAsFlavor           Boolean                   @default(true)
  halfAndHalfFlavorCategoryId String?

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization              Organization     @relation(fields: [organizationId], references: [id])
  catalogCategory           CatalogCategory  @relation(fields: [catalogCategoryId], references: [id])
  halfAndHalfFlavorCategory CatalogCategory? @relation("HalfAndHalfFlavorCategory", fields: [halfAndHalfFlavorCategoryId], references: [id])

  eventProducts          EventProduct[]
  orderItems             OrderItem[]
  onlineOrderItems       OnlineOrderItem[]
  orderItemFlavors       OrderItemFlavor[]
  onlineOrderItemFlavors OnlineOrderItemFlavor[]
  optionGroups           CatalogProductOptionGroup[]
  linkedProductOptions   CatalogProductOption[]      @relation("CatalogProductOptionLinkedProduct")

  @@unique([organizationId, slug])
  @@index([halfAndHalfFlavorCategoryId])
}

model EventProduct {
  id               String @id @default(cuid())
  eventId          String
  catalogProductId String

  priceInCents Int?

  trackStock    Boolean @default(false)
  stockQuantity Int?
  soldOut       Boolean @default(false)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  event          Event          @relation(fields: [eventId], references: [id])
  catalogProduct CatalogProduct @relation(fields: [catalogProductId], references: [id])

  @@unique([eventId, catalogProductId])
}

model EventPrintJob {
  id            String  @id @default(cuid())
  eventId       String?
  orderId       String?
  storeId       String?
  onlineOrderId String?

  idempotencyKey String? @unique

  printerId String?
  deviceId  String?

  sector CategorySector
  status PrintJobStatus @default(PENDING)

  payload Json

  printedAt    DateTime?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  event       Event?        @relation(fields: [eventId], references: [id])
  order       Order?        @relation(fields: [orderId], references: [id])
  store       OnlineStore?  @relation(fields: [storeId], references: [id])
  onlineOrder OnlineOrder?  @relation(fields: [onlineOrderId], references: [id])
  printer     EventPrinter? @relation(fields: [printerId], references: [id])
  device      Device?       @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([eventId])
  @@index([orderId])
  @@index([storeId])
  @@index([onlineOrderId])
}

model EventPrinter {
  id      String @id @default(cuid())
  eventId String

  name   String
  sector PrinterSector

  connectionType PrinterConnectionType @default(TCP_IP)

  ipAddress String
  port      Int    @default(9100)

  paperSize String  @default("80mm")
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  event     Event           @relation(fields: [eventId], references: [id])
  printJobs EventPrintJob[]
}

model PaymentProviderSettings {
  id             String @id @default(cuid())
  organizationId String

  provider PaymentProvider

  enabled Boolean @default(false)

  pixEnabled      Boolean @default(false)
  cardEnabled     Boolean @default(false)
  terminalEnabled Boolean @default(false)

  accessToken   String?
  publicKey     String?
  webhookSecret String?
  webhookUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider])
}

model OrganizationPaymentSettings {
  id             String @id @default(cuid())
  organizationId String @unique

  pixEnabled        Boolean @default(false)
  creditEnabled     Boolean @default(false)
  debitEnabled      Boolean @default(false)
  cashEnabled       Boolean @default(true)
  nfcBalanceEnabled Boolean @default(false)

  defaultProvider      PaymentProvider    @default(MANUAL)
  pixExpirationMinutes Int                @default(5)
  maxInstallments      Int                @default(1)
  environment          PaymentEnvironment @default(PRODUCTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PaymentProviderCredential {
  id             String @id @default(cuid())
  organizationId String

  provider    PaymentProvider
  environment PaymentEnvironment @default(PRODUCTION)

  encryptedCredentials String?
  publicMetadata       Json?
  keyVersion           String?
  active               Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, environment])
  @@index([organizationId])
  @@index([provider])
  @@index([environment])
  @@index([active])
}

model ContextPaymentSettings {
  id             String @id @default(cuid())
  organizationId String

  contextType   PaymentContextType
  eventId       String?
  onlineStoreId String?

  inheritOrganizationSettings Boolean @default(true)

  pixEnabledOverride        Boolean?
  creditEnabledOverride     Boolean?
  debitEnabledOverride      Boolean?
  cashEnabledOverride       Boolean?
  nfcBalanceEnabledOverride Boolean?
  maxInstallmentsOverride   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  onlineStore  OnlineStore? @relation(fields: [onlineStoreId], references: [id], onDelete: Cascade)

  @@unique([organizationId, contextType, eventId, onlineStoreId])
  @@index([organizationId])
  @@index([eventId])
  @@index([onlineStoreId])
  @@index([contextType])
}

model PaymentTerminal {
  id             String  @id @default(cuid())
  organizationId String
  deviceId       String?
  eventId        String?
  onlineStoreId  String?

  provider           PaymentProvider
  externalTerminalId String
  status             PaymentTerminalStatus @default(ACTIVE)
  active             Boolean               @default(true)
  lastSeenAt         DateTime?
  metadata           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  device       Device?              @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  event        Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)
  onlineStore  OnlineStore?         @relation(fields: [onlineStoreId], references: [id], onDelete: SetNull)
  transactions PaymentTransaction[]

  @@unique([organizationId, provider, externalTerminalId])
  @@index([organizationId])
  @@index([deviceId])
  @@index([eventId])
  @@index([onlineStoreId])
  @@index([provider])
  @@index([active])
}

model PaymentRefund {
  id                   String @id @default(cuid())
  organizationId       String
  paymentTransactionId String

  provider         PaymentProvider
  status           PaymentRefundStatus @default(REQUESTED)
  amountInCents    Int
  reason           String?
  externalRefundId String?
  idempotencyKey   String?             @unique
  gatewayStatus    String?
  gatewayMessage   String?
  metadata         Json?
  requestedAt      DateTime            @default(now())
  completedAt      DateTime?
  failedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([paymentTransactionId])
  @@index([provider])
  @@index([status])
}

model PaymentWebhookEvent {
  id             String  @id @default(cuid())
  organizationId String?

  provider          PaymentProvider
  externalEventId   String?
  externalPaymentId String?
  idempotencyKey    String?         @unique
  eventType         String?
  processed         Boolean         @default(false)
  ignored           Boolean         @default(false)
  reason            String?
  payload           Json?
  headers           Json?
  processedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([provider])
  @@index([externalPaymentId])
  @@index([processed])
  @@index([createdAt])
}

model PaymentSettingsMigrationConflict {
  id             String @id @default(cuid())
  organizationId String

  conflictType String
  details      Json
  resolved     Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conflictType])
  @@index([resolved])
}

model EventClosing {
  id String @id @default(cuid())

  eventId        String
  organizationId String
  closedByUserId String?

  totalOrders     Int
  paidOrders      Int
  pendingOrders   Int
  cancelledOrders Int

  receivedInCents      Int
  pendingInCents       Int
  cancelledInCents     Int
  averageTicketInCents Int

  pixManualInCents    Int @default(0)
  pixAutomaticInCents Int @default(0)
  cashInCents         Int @default(0)
  creditCardInCents   Int @default(0)
  debitCardInCents    Int @default(0)
  courtesyInCents     Int @default(0)
  otherInCents        Int @default(0)

  printPendingCount   Int @default(0)
  printPrintedCount   Int @default(0)
  printErrorCount     Int @default(0)
  printCancelledCount Int @default(0)

  notes String?

  closedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  closedByUser User?        @relation(fields: [closedByUserId], references: [id])

  @@unique([eventId])
  @@index([organizationId])
  @@index([closedByUserId])
  @@index([closedAt])
}

model Device {
  id String @id @default(cuid())

  organizationId String
  eventId        String?
  storeId        String?

  name String
  code String @unique

  auditLogs AuditLog[]

  locationName String?

  type   DeviceType
  status DeviceStatus @default(ACTIVE)

  authStatus DeviceAuthStatus @default(PENDING)

  tokenHash        String?
  deviceSecretHash String?

  appVersion String?

  lastSeenAt      DateTime?
  lastHeartbeatAt DateTime?
  lastActivatedAt DateTime?

  lastIpAddress String?
  lastUserAgent String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])
  store        OnlineStore? @relation(fields: [storeId], references: [id])

  orders              Order[]
  printJobs           EventPrintJob[]
  paymentTerminals    PaymentTerminal[]
  paymentTransactions PaymentTransaction[]
  nfcCardReads        NfcCardRead[]

  @@index([organizationId])
  @@index([eventId])
  @@index([storeId])
  @@index([status])
  @@index([authStatus])
  @@index([type])
}

enum AuditAction {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  ORDER_PAYMENT_STATUS_UPDATED

  PAYMENT_CREATED
  PAYMENT_APPROVED
  PAYMENT_EXPIRED
  PAYMENT_REJECTED
  PAYMENT_REFUNDED
  PAYMENT_MANUAL_MARKED
  PAYMENT_PROVIDER_SETTINGS_UPDATED
  PAYMENT_PROVIDER_CONFIGURED
  PAYMENT_CREDENTIAL_UPDATED
  PAYMENT_SETTINGS_UPDATED
  PAYMENT_METHOD_ENABLED
  PAYMENT_METHOD_DISABLED
  PAYMENT_TERMINAL_LINKED
  PAYMENT_DECLINED
  PAYMENT_CANCELLED
  PAYMENT_REFUND_REQUESTED
  PAYMENT_REFUND_COMPLETED
  PRINTING_SETTINGS_UPDATED

  EVENT_CREATED
  EVENT_UPDATED
  EVENT_CLOSED

  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_ACTIVATED
  PRODUCT_DEACTIVATED
  HALF_AND_HALF_ENABLED
  HALF_AND_HALF_DISABLED
  FLAVOR_ELIGIBILITY_ENABLED
  FLAVOR_ELIGIBILITY_DISABLED
  PRODUCT_PRICE_CHANGED
  PRODUCT_OPTION_CHANGED

  EVENT_PRODUCT_CREATED
  EVENT_PRODUCT_UPDATED
  EVENT_PRODUCT_DELETED

  IMAGE_UPLOADED

  DEVICE_CREATED
  DEVICE_ACTIVATED
  DEVICE_REVOKED

  PRINT_JOB_CREATED
  PRINT_JOB_PRINTED
  PRINT_JOB_ERROR

  USER_LOGGED_IN
  USER_CREATED

  NFC_CARD_CREATED
