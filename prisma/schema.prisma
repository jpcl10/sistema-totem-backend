model AuditLog {
  id String @id @default(cuid())

  organizationId String
  eventId        String?

  userId   String?
  deviceId String?

  entity   String
  entityId String?

  action AuditAction

  description String?

  metadata Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  event Event? @relation(fields: [eventId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  device Device? @relation(fields: [deviceId], references: [id])

  @@index([organizationId])
  @@index([eventId])
  @@index([userId])
  @@index([deviceId])
  @@index([action])
  @@index([createdAt])
}

model NfcCard {
  id             String        @id @default(cuid())
  organizationId String
  eventId        String
  uid            String        @unique
  code           String?
  holderName     String?
  type           NfcCardType   @default(CUSTOMER)
  status         NfcCardStatus @default(ACTIVE)
  balanceInCents Int           @default(0)
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  event               Event                @relation(fields: [eventId], references: [id])
  nfcCardReads        NfcCardRead[]
  nfcCardTransactions NfcCardTransaction[]

  @@index([organizationId])
  @@index([eventId])
  @@index([uid])
  @@index([status])
  @@index([type])
}

model NfcCardTransaction {
  id                   String                 @id @default(cuid())
  organizationId       String
  eventId              String
  nfcCardId            String
  userId               String?
  type                 NfcCardTransactionType
  amountInCents        Int
  balanceBeforeInCents Int
  balanceAfterInCents  Int
  description          String?
  metadata             Json?
  createdAt            DateTime               @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])
  nfcCard      NfcCard      @relation(fields: [nfcCardId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([eventId])
  @@index([nfcCardId])
  @@index([type])
  @@index([createdAt])
}

model NfcCardRead {
  id             String        @id @default(cuid())
  organizationId String
  eventId        String
  nfcCardId      String
  userId         String?
  deviceId       String?
  uid            String
  source         NfcReadSource @default(ADMIN_PANEL)
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])
  nfcCard      NfcCard      @relation(fields: [nfcCardId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  device       Device?      @relation(fields: [deviceId], references: [id])

  @@index([organizationId])
  @@index([eventId])
  @@index([nfcCardId])
  @@index([userId])
  @@index([deviceId])
  @@index([createdAt])
}

enum ModuleKey {
  ONLINE_ORDERS
  TOTEM
  EVENTS
  PAYMENTS
  PRINTING
  NFC_CASHLESS
  FINANCIAL
  DEVICES
  REPORTS
  DELIVERY
  WHATSAPP
  LOYALTY
}

enum OnlineOrderPaymentMethod {
  PIX
  CARD_ON_DELIVERY
  CASH
}

enum OnlineOrderFulfillmentType {
  DELIVERY
  PICKUP
  COUNTER
  DINE_IN
}

enum OnlineOrderStatus {
  RECEIVED
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderSource {
  DIGITAL_MENU
  WHATSAPP
  ADMIN
  POS
  API
}

enum DeliveryFeeRuleType {
  FLAT
  NEIGHBORHOOD
}

enum CustomerInterestSource {
  MANUAL
  ONLINE_ORDER
  EVENT
  IMPORT
  API
}

enum CustomerSource {
  ONLINE
  EVENT
  ADMIN
  IMPORT
  API
  TOTEM
  POS
  WHATSAPP
}

enum CatalogProductPricingRule {
  STANDARD
  MAX_SELECTED_FLAVOR
}

model OrganizationModule {
  id             String    @id @default(cuid())
  organizationId String
  moduleKey      ModuleKey
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, moduleKey])
  @@index([organizationId])
  @@index([moduleKey])
}

model BusinessHour {
  id             String              @id @default(cuid())
  organizationId String
  contextType    SettingsContextType
  storeId        String?
  channel        SettingsChannel     @default(ALL)

  dayOfWeek   Int
  periodIndex Int
  opensAt     String
  closesAt    String
  isClosed    Boolean @default(false)
  is24Hours   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        OnlineStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([organizationId, contextType, storeId, channel, dayOfWeek, periodIndex])
  @@index([organizationId])
  @@index([storeId])
  @@index([channel])
  @@index([dayOfWeek])
}

model BusinessHourException {
  id             String          @id @default(cuid())
  organizationId String
  storeId        String?
  channel        SettingsChannel @default(ALL)

  date      DateTime @db.Date
  isClosed  Boolean  @default(false)
  is24Hours Boolean  @default(false)
  opensAt   String?
  closesAt  String?
  reason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        OnlineStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([storeId])
  @@index([channel])
  @@index([date])
}

model OnlineStore {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  slug           String  @unique
  whatsapp       String
  city           String
  address        String?
  logoUrl        String?
  bannerUrl      String?
  isOpen         Boolean @default(true)
  active         Boolean @default(true)

  manualOverrideMode            StoreManualOverrideMode @default(AUTO)
  manualOverrideUntil           DateTime?
  manualOverrideReason          String?
  manualOverrideUpdatedAt       DateTime?
  manualOverrideUpdatedByUserId String?

  printingEnabled  Boolean   @default(false)
  autoPrintEnabled Boolean   @default(false)
  printMode        PrintMode @default(FULL_ORDER)
  printerPaperSize String    @default("80mm")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization           Organization             @relation(fields: [organizationId], references: [id])
  orders                 OnlineOrder[]
  devices                Device[]
  printJobs              EventPrintJob[]
  categories             OnlineCategory[]
  products               OnlineProduct[]
  businessHours          BusinessHour[]
  businessHourExceptions BusinessHourException[]
  settings               OnlineStoreSettings?
  deliveryFeeRules       DeliveryFeeRule[]
  contextPaymentSettings ContextPaymentSettings[]
  paymentTerminals       PaymentTerminal[]

  @@index([organizationId])
  @@index([slug])
}

model OnlineStoreSettings {
  id             String @id @default(cuid())
  organizationId String
  storeId        String @unique

  onlineOrderingEnabled Boolean @default(true)
  digitalMenuEnabled    Boolean @default(true)

  deliveryEnabled Boolean @default(false)
  pickupEnabled   Boolean @default(true)
  counterEnabled  Boolean @default(false)
  dineInEnabled   Boolean @default(false)

  allowOrdersOutsideHours Boolean @default(false)
  autoAcceptOrders        Boolean @default(false)

  minimumOrderInCents         Int  @default(0)
  estimatedPreparationMinutes Int  @default(30)
  estimatedDeliveryMinutes    Int  @default(45)
  freeDeliveryAboveInCents    Int?
  defaultDeliveryFeeInCents   Int  @default(0)

  closedMessage            String?
  checkoutNotice           String?
  orderConfirmationMessage String?

  requireCustomerName    Boolean @default(true)
  requireCustomerPhone   Boolean @default(true)
  requireDeliveryAddress Boolean @default(true)
  allowCustomerNotes     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        OnlineStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([storeId])
}

model DeliveryFeeRule {
  id             String              @id @default(cuid())
  organizationId String
  storeId        String
  name           String
  type           DeliveryFeeRuleType

  neighborhood String?
  feeInCents   Int

  estimatedMinutes         Int?
  minimumOrderInCents      Int?
  freeDeliveryAboveInCents Int?
  active                   Boolean @default(true)
  sortOrder                Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        OnlineStore   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders       OnlineOrder[]

  @@index([organizationId])
  @@index([storeId])
  @@index([type])
  @@index([active])
  @@index([sortOrder])
}

model OnlineCategory {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  slug      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  store    OnlineStore     @relation(fields: [storeId], references: [id])
  products OnlineProduct[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model OnlineProduct {
  id           String   @id @default(cuid())
  storeId      String
  categoryId   String
  name         String
  description  String?
  imageUrl     String?
  priceInCents Int
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  store      OnlineStore       @relation(fields: [storeId], references: [id])
  category   OnlineCategory    @relation(fields: [categoryId], references: [id])
  orderItems OnlineOrderItem[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([categoryId])
}

model OnlineOrder {
  id                   String                     @id @default(cuid())
  storeId              String
  orderNumber          Int
  customerId           String?
  customerAddressId    String?
  customerName         String
  customerPhone        String
  deliveryAddress      String
  deliveryNumber       String
  deliveryNeighborhood String
  deliveryComplement   String?
  deliveryReference    String?
  paymentMethod        OnlineOrderPaymentMethod
  paymentStatus        PaymentStatus              @default(PENDING)
  source               OrderSource                @default(DIGITAL_MENU)
  fulfillmentType      OnlineOrderFulfillmentType @default(DELIVERY)
  deliveryRuleId       String?
  estimatedMinutes     Int?
  changeForInCents     Int?
  subtotalInCents      Int
  deliveryFeeInCents   Int                        @default(0)
  totalInCents         Int
  status               OnlineOrderStatus          @default(RECEIVED)
  notes                String?
  paidAt               DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @default(now()) @updatedAt

  store               OnlineStore          @relation(fields: [storeId], references: [id])
  deliveryRule        DeliveryFeeRule?     @relation(fields: [deliveryRuleId], references: [id])
  customer            Customer?            @relation(fields: [customerId], references: [id])
  customerAddress     CustomerAddress?     @relation(fields: [customerAddressId], references: [id])
  items               OnlineOrderItem[]
  printJobs           EventPrintJob[]
  paymentTransactions PaymentTransaction[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([deliveryRuleId])
  @@index([customerId])
  @@index([customerAddressId])
}

model OnlineOrderItem {
  id               String   @id @default(cuid())
  orderId          String
  productId        String?
  catalogProductId String?
  productName      String
  quantity         Int
  unitPriceInCents Int
  totalInCents     Int
  notes            String?
  pricingSnapshot  Json?
  createdAt        DateTime @default(now())

  order          OnlineOrder             @relation(fields: [orderId], references: [id])
  product        OnlineProduct?          @relation(fields: [productId], references: [id])
  catalogProduct CatalogProduct?         @relation(fields: [catalogProductId], references: [id])
  options        OnlineOrderItemOption[]
  flavors        OnlineOrderItemFlavor[]

  @@index([orderId])
  @@index([productId])
  @@index([catalogProductId])
}

model OrderItemFlavor {
  id               String  @id @default(cuid())
  orderItemId      String
  catalogProductId String?
  position         Int
  flavorName       String
  priceInCents     Int

  orderItem      OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  catalogProduct CatalogProduct? @relation(fields: [catalogProductId], references: [id])

  createdAt DateTime @default(now())

  @@unique([orderItemId, position])
  @@index([orderItemId])
  @@index([catalogProductId])
}

model OnlineOrderItemFlavor {
  id                String  @id @default(cuid())
  onlineOrderItemId String
  catalogProductId  String?
  position          Int
  flavorName        String
  priceInCents      Int

  onlineOrderItem OnlineOrderItem @relation(fields: [onlineOrderItemId], references: [id], onDelete: Cascade)
  catalogProduct  CatalogProduct? @relation(fields: [catalogProductId], references: [id])

  createdAt DateTime @default(now())

  @@unique([onlineOrderItemId, position])
  @@index([onlineOrderItemId])
  @@index([catalogProductId])
}

model Customer {
  id                 String         @id @default(cuid())
  organizationId     String
  name               String
  phone              String?
  normalizedPhone    String?
  email              String?
  normalizedEmail    String?
  document           String?
  normalizedDocument String?
  birthDate          DateTime?
  notes              String?
  active             Boolean        @default(true)
  firstSource        CustomerSource @default(ADMIN)
  lastSource         CustomerSource @default(ADMIN)
  firstSeenAt        DateTime       @default(now())
  lastSeenAt         DateTime       @default(now())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @default(now()) @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  addresses         CustomerAddress[]
  customerInterests CustomerInterest[]
  onlineOrders      OnlineOrder[]
  orders            Order[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@index([organizationId, normalizedPhone])
  @@index([organizationId, normalizedEmail])
  @@index([organizationId, normalizedDocument])
}

model CustomerAddress {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  label          String?  @map("title")
  recipientName  String?
  street         String
  number         String?
  neighborhood   String?
  city           String?
  state          String?
  postalCode     String?
  complement     String?
  reference      String?
  active         Boolean  @default(true)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
  orders       OnlineOrder[]

  @@index([organizationId, customerId])
  @@index([customerId])
}

model Interest {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  key            String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  customerInterests CustomerInterest[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model CustomerInterest {
  id         String                  @id @default(cuid())
  customerId String
  interestId String
  source     CustomerInterestSource?
  createdAt  DateTime                @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  interest Interest @relation(fields: [interestId], references: [id])

  @@unique([customerId, interestId])
  @@index([interestId])
}

// Grupo de opções para produto (ex: "Escolha a borda")
model CatalogProductOptionGroup {
  id             String @id @default(cuid())
  organizationId String
  productId      String

  name          String
  key           String
  description   String?
  required      Boolean @default(false)
  minSelections Int     @default(0)
  maxSelections Int     @default(1)
  sortOrder     Int     @default(0)
  active        Boolean @default(true)

  organization Organization           @relation(fields: [organizationId], references: [id])
  product      CatalogProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options      CatalogProductOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([productId, key])
  @@index([organizationId])
  @@index([productId])
}

// Opção individual (ex: "Borda recheada")
model CatalogProductOption {
  id             String @id @default(cuid())
  organizationId String
  optionGroupId  String

  name              String
  key               String
  description       String?
  priceDeltaInCents Int     @default(0)

  linkedProductId String?

  sortOrder Int     @default(0)
  active    Boolean @default(true)

  organization  Organization              @relation(fields: [organizationId], references: [id])
  optionGroup   CatalogProductOptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  linkedProduct CatalogProduct?           @relation("CatalogProductOptionLinkedProduct", fields: [linkedProductId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([optionGroupId, key])
  @@index([organizationId])
  @@index([optionGroupId])
  @@index([linkedProductId])
}

// Opção selecionada em item de pedido de evento
model OrderItemOption {
  id          String @id @default(cuid())
  orderItemId String

  optionGroupId   String?
  optionId        String?
  linkedProductId String?

  groupName         String
  optionName        String
  priceDeltaInCents Int

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderItemId])
}

// Opção selecionada em item de pedido online
model OnlineOrderItemOption {
  id                String @id @default(cuid())
  onlineOrderItemId String

  optionGroupId   String?
  optionId        String?
  linkedProductId String?

  groupName         String
  optionName        String
  priceDeltaInCents Int

  onlineOrderItem OnlineOrderItem @relation(fields: [onlineOrderItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([onlineOrderItemId])
}
