  CUSTOMER_ADDRESS_STATUS_UPDATED
  INTEREST_CREATED
  INTEREST_UPDATED
  INTEREST_STATUS_UPDATED
  CUSTOMER_INTEREST_ADDED
  CUSTOMER_INTEREST_REMOVED
  SETTINGS_GENERAL_UPDATED
  SETTINGS_BRANDING_UPDATED
  BUSINESS_HOURS_UPDATED
